# SwitchMap production template for the internal server.
# Copy this content into switchmap.env and edit the host/IP/secret values.

SWITCHMAP_DEBUG=False
SWITCHMAP_SECRET_KEY=replace-with-a-long-random-secret-key-at-least-50-characters
SWITCHMAP_ALLOWED_HOSTS=127.0.0.1,localhost,switchmap,192.168.0.250
SWITCHMAP_CSRF_TRUSTED_ORIGINS=http://switchmap:8000,http://192.168.0.250:8000
SWITCHMAP_SQLITE_PATH=db.sqlite3
SWITCHMAP_SQLITE_BACKUP_DIR=backups/sqlite
SWITCHMAP_SQLITE_BACKUP_RETENTION=30
SWITCHMAP_LOG_DIR=logs
SWITCHMAP_LOG_LEVEL=INFO

SWITCHMAP_WAITRESS_HOST=0.0.0.0
SWITCHMAP_WAITRESS_PORT=8000
SWITCHMAP_WAITRESS_THREADS=8
SWITCHMAP_WAITRESS_URL_SCHEME=http

# Keep these disabled for plain internal HTTP.
SWITCHMAP_SECURE_SSL_REDIRECT=False
SWITCHMAP_SESSION_COOKIE_SECURE=False
SWITCHMAP_CSRF_COOKIE_SECURE=False
SWITCHMAP_SECURE_HSTS_SECONDS=0
SWITCHMAP_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SWITCHMAP_SECURE_HSTS_PRELOAD=False

# Enable these only if SwitchMap is published behind trusted HTTPS.
# SWITCHMAP_CSRF_TRUSTED_ORIGINS=https://switchmap.winac-co.com
# SWITCHMAP_SECURE_SSL_REDIRECT=True
# SWITCHMAP_SESSION_COOKIE_SECURE=True
# SWITCHMAP_CSRF_COOKIE_SECURE=True
# SWITCHMAP_SECURE_HSTS_SECONDS=31536000
# SWITCHMAP_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SWITCHMAP_SECURE_HSTS_PRELOAD=True

# Use only when Django is behind a trusted reverse proxy that sets this header.
# SWITCHMAP_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
